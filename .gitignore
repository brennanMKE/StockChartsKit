# macOS
.DS_Store

# Swift Package Manager
/.build
/Packages
*.xcodeproj/

# Xcode / SwiftPM IDE state
xcuserdata/
DerivedData/
.swiftpm/configuration/registries.json
.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata
.swiftpm/xcode/xcuserdata/

# Credentials — never commit. Secrets live in the macOS Keychain at runtime.
.netrc
.env
.env.*
*.pem
*.p8
*.p12
*.key
secrets.json
**/Secrets.swift

# Runtime data — local snapshot store and market-data cache (see PRD §7).
# Fixtures under Tests/**/Fixtures/ are kept (see .gitattributes); only
# stray runtime DBs at the repo root / build dirs are ignored.
/*.sqlite
/*.sqlite-shm
/*.sqlite-wal
